# ── Database ──
DATABASE_URL="mysql://root:password@localhost:3306/dashboard_smt"

# ── JWT ──
# WAJIB ganti di production! Generate secret kuat minimal 64 karakter, contoh:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-secret-random-minimal-64-karakter-di-production"
# Masa berlaku token. Production disarankan pendek (4h - 8h).
JWT_EXPIRES_IN="8h"

# ── Server ──
PORT=5000
NODE_ENV=development

# ── CORS ──
# WAJIB di-set pada production dengan domain frontend, contoh: https://dashboard.serbamulia.com
FRONTEND_URL="http://localhost:5173"
